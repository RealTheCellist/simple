PORT=3000
HOST=0.0.0.0
NODE_ENV=development
MOCK_FALLBACK=true
UPSTREAM_TIMEOUT_MS=9000
CACHE_TTL_MS=5000
CORS_ORIGIN=*
REALTIME_ENABLED=true
REALTIME_PATH=/ws
REALTIME_BROADCAST_MS=5000
ENTERPRISE_ENABLED=true
ENTERPRISE_TOKEN_SECRET=change_this_secret_in_prod
ENTERPRISE_TOKEN_TTL_SEC=28800
ENTERPRISE_AUDIT_MAX_ENTRIES=2000
